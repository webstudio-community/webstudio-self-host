# ── Builder image ─────────────────────────────────────────────────────────────
# Use a specific tag to pin the version (e.g. ghcr.io/webstudio-community/builder:1.2.3)
BUILDER_IMAGE=ghcr.io/webstudio-community/builder:latest

# ── Publisher image ───────────────────────────────────────────────────────────
PUBLISHER_IMAGE=ghcr.io/webstudio-community/webstudio-publisher:latest

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── PostgREST ─────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
PGRST_JWT_SECRET=change-me-64-char-minimum-secret-generate-with-the-command-above

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me

# Option A — simple dev login (password = AUTH_SECRET value)
DEV_LOGIN=true
DEV_LOGIN_EMAIL=admin@example.com

# Option B — OAuth via GitHub (comment out DEV_LOGIN and fill these in)
# GH_CLIENT_ID=
# GH_CLIENT_SECRET=

# Option C — OAuth via Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=


# ── Feature flags ─────────────────────────────────────────────────────────────
FEATURES=*
USER_PLAN=Pro
MAX_ASSETS_PER_PROJECT=50

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-password

# ── Asset storage (S3) ────────────────────────────────────────────────────────
# Default: MinIO running in the same stack (http://minio:9000).
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY must match MINIO_ROOT_USER / PASSWORD above.
# Replace S3_ENDPOINT with an external S3-compatible URL to use remote storage instead.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-strong-password
S3_BUCKET=webstudio-assets

# ── Publish / static file serving ─────────────────────────────────────────────
# The subdomain suffix for published projects (e.g. myproject.example.com).
# Set this to your own domain that has a wildcard DNS record (*.example.com) pointing to this server.
# PUBLISHER_HOST=example.com

# Service-to-service API token used by the publisher to authenticate with the builder.
# Generate with: openssl rand -hex 32
# TRPC_SERVER_API_TOKEN=

# ── Cloudflare Pages publish destination (optional) ───────────────────────────
# Set these to enable `buildMode: "cloudflare"` in publish requests.
# The publisher will deploy to Cloudflare Pages via wrangler instead of local Nginx.
# Get your API token at https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# URL of the publisher service, used by the builder to trigger publishes.
# Set to http://publisher:4000 to enable one-click publish.
SELF_HOSTED_PUBLISHER_URL=http://publisher:4000

# ── Entri (automatic DNS configuration) ───────────────────────────────────────
# Optional. Get credentials at https://entri.com/
# When set, the "Setup automatically with Entri" button is enabled for all users
# regardless of their plan (self-hosting bypasses the Pro plan requirement).
# ENTRI_APPLICATION_ID=webstudio
# ENTRI_SECRET=
